# Copia este archivo como .env y completa con tus credenciales reales.
# El archivo .env NUNCA se sube a Git (está en .gitignore).

PORT=3000

# Conexión a PostgreSQL (Supabase) — reemplaza TU_PASSWORD por tu contraseña real
